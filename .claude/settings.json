{
  "permissions": {
    "deny": ["Read(./.env)", "Read(./.env.*)"]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '{event: \"Needs input\", message: .message}' > /tmp/claude-notify.pipe"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"event\": \"Done\", \"message\": \"Task finished\"}' > /tmp/claude-notify.pipe"
          }
        ]
      }
    ]
  }
}