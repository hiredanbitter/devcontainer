{
  "permissions": {
    "allow": [
      "Bash",
      "Read",
      "Write",
      "Edit",
      "MultiEdit",
      "Glob",
      "Grep",
      "LS",
      "WebFetch",
      "WebSearch"
    ],
    "ask": [
      "Bash(git *)",
      "Bash(gh *)"
    ],
    "deny": [
      "Read(./.env)", "Read(./.env.*)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -fd*)",
      "Bash(git clean -fdx*)",
      "Bash(gh pr merge*)",
      "Bash(gh repo delete*)"
    ]
  },
  "hooks": {
    "Notification": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "jq -c '{event: \"Needs input\", message: .message}' > /tmp/claude-notify.pipe"
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "echo '{\"event\": \"Done\", \"message\": \"Task finished\"}' > /tmp/claude-notify.pipe"
          }
        ]
      }
    ]
  }
}